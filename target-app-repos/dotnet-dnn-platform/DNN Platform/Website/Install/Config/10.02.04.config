<configuration>
  <nodes configfile="web.config">
    <node path="/configuration/appSettings" action="update" key="key" collision="ignore">
      <add key="AllowDnnUpgradeUpload" value="true" />
    </node>
    <node path="/configuration/system.web/httpRuntime" action="updateattribute"  name="requestLengthDiskThreshold" value="80" />
    <node path="/configuration/appSettings/add[@key='AllowDnnUpgradeUpload' and following-sibling::add[@key='AllowDnnUpgradeUpload']]" action="remove" />
  </nodes>
</configuration>