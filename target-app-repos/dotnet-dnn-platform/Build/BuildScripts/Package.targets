<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="3.5" DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <DotNetNukeMSBuildTasksLib>$(BuildScriptsPath)\DotNetNuke.MSBuild.Tasks.dll</DotNetNukeMSBuildTasksLib>
  </PropertyGroup>

  <UsingTask TaskName="ExtensionPackager" TaskFactory="RoslynCodeTaskFactory" AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <ParameterGroup>
      <WorkingFolder ParameterType="System.String" />
      <Manifest Required="true" ParameterType="System.String" />
      <PackageFiles Output="true" ParameterType="Microsoft.Build.Framework.ITaskItem[]" />
    </ParameterGroup>
    <Task>
      <Using Namespace="Microsoft.Build.Utilities" />
      <Using Namespace="System.Collections.Generic" />
      <Using Namespace="System.IO" />
      <Using Namespace="System.Linq" />
      <Using Namespace="System.Xml.Linq" />
      <Code Type="Fragment" Language="cs">
<![CDATA[
    this.PackageFiles = (
        from package in XDocument.Load(Path.Combine(this.WorkingFolder ?? string.Empty, this.Manifest)).Descendants("package")
        from component in package.Element("components").Descendants("component")
        let componentType = component.Attribute("type").Value
        from file in component.Descendants().Descendants<XElement>(componentType.ToLowerInvariant())
        where file.Attribute("action")?.Value != "UnRegister"
        let path = file.Element("path")
        let name = file.Element("name")
        let sourceFileName = file.Element("sourceFileName")
        let fullFilePath = sourceFileName?.Value ?? Path.Combine(path?.Value ?? string.Empty, name.Value)
        select new TaskItem(fullFilePath, new Dictionary<string, object> { { "RecursiveDir", Path.GetDirectoryName(fullFilePath) }, })
    ).ToArray();
]]>
      </Code>
    </Task>
  </UsingTask>

  <Target Name="Package" Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU'">
    <XmlPeek Namespaces="&lt;Namespace Prefix='n' Uri='http://schemas.microsoft.com/developer/msbuild/2003' /&gt;"
             Query="dotnetnuke/packages/package/@version"
             XmlInputPath="$(DNNFileName).dnn">
      <Output TaskParameter="Result" PropertyName="Version" />
    </XmlPeek>
    <ExtensionPackager Manifest="$(DNNFileName).dnn" WorkingFolder="$(MSBuildProjectDirectory)\">
      <Output TaskParameter="PackageFiles" ItemName="PackageFiles">
      </Output>
    </ExtensionPackager>

    <CallTarget Condition="'$(UseResourceZipWorkingDirectory)' == 'True'" Targets="RezipResources" />
    <Copy SourceFiles="$(DNNFileName).dnn" DestinationFolder="$(MSBuildProjectDirectory)\Package" />
    <Zip Condition="'$(UseResourceZipWorkingDirectory)' != 'True'" Files="@(Resources)" WorkingDirectory="$(MSBuildProjectDirectory)" ZipFileName="$(MSBuildProjectDirectory)\Package\Resources.zip" />

    <ItemGroup>
      <LicenseFiles Include="license.txt"/>
    </ItemGroup>
    <Copy SourceFiles="@(LicenseFiles)" DestinationFolder="$(MSBuildProjectDirectory)\Package" />
    
    <ItemGroup>
      <ReleaseNotesFiles Include="releaseNotes.txt"/>
    </ItemGroup>
    <Copy SourceFiles="@(ReleaseNotesFiles)" DestinationFolder="$(MSBuildProjectDirectory)\Package" />
    
    <Copy SourceFiles="@(PackageFiles)" DestinationFolder="$(MSBuildProjectDirectory)\Package\%(PackageFiles.RecursiveDir)" />
    
    <ItemGroup>
      <ZipOutputContent Include="$(MSBuildProjectDirectory)\Package\**\*.*" />
    </ItemGroup>
    <Zip Files="@(ZipOutputContent)" WorkingDirectory="$(MSBuildProjectDirectory)\Package" ZipFileName="$(PackageName)_$(Version)_Install.$(Extension)" />
    <Move SourceFiles="$(MSBuildProjectDirectory)\$(PackageName)_$(Version)_Install.$(Extension)" DestinationFolder="$(InstallPath)" />

    <RemoveDir Directories="$(MSBuildProjectDirectory)\Package" ContinueOnError="WarnAndContinue" />
  </Target>

  <Target Name="RezipResources">
    <MakeDir Directories="$(MSBuildProjectDirectory)\Package"/>
    <Zip Files="@(Resources)" WorkingDirectory="$(MSBuildProjectDirectory)" ZipFileName="$(MSBuildProjectDirectory)\Package\Resources.zip" />
    <Unzip ZipFileName="$(MSBuildProjectDirectory)\Package\Resources.zip" TargetDirectory="$(MSBuildProjectDirectory)\Package\Resources" />
    <Delete Files="$(MSBuildProjectDirectory)\Package\Resources.zip" />
    <ItemGroup>
      <_Step2FilesToZip Include="$(MSBuildProjectDirectory)\Package\Resources\**\*" />
    </ItemGroup>

    <Zip Files="@(_Step2FilesToZip)" WorkingDirectory="$(ResourceZipWorkingDirectory)"
         ZipFileName="$(MSBuildProjectDirectory)\Package\Resources.zip" />
    <RemoveDir Directories ="$(MSBuildProjectDirectory)\Package\Resources" ContinueOnError="WarnAndContinue" />
  </Target>
</Project>
